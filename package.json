{
  "name": "civicflow-workspace",
  "version": "1.0.0",
  "description": "CivicFlow Monorepo Workspace",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently --kill-others \"npm run dev:backend\" \"npm run dev:wait-frontend\"",
    "dev:wait-frontend": "wait-on tcp:5000 && npm run dev:frontend",
    "prisma:generate": "npm run prisma:generate --prefix backend",
    "prisma:migrate": "npm run prisma:migrate --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "wait-on": "^9.0.10"
  }
}
